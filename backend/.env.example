# Postgres. Production target is a hosted Neon database. Must use the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
# Local dev alternative using the Postgres service in docker-compose.dev.yml:
#   DATABASE_URL=postgresql+asyncpg://deploy:deploy@localhost:5432/deploy_pipeline

# Separate database used only by the test suite.
TEST_DATABASE_URL=postgresql+asyncpg://user:password@host/dbname_test
# Local dev alternative (created by the compose init script):
#   TEST_DATABASE_URL=postgresql+asyncpg://deploy:deploy@localhost:5432/deploy_pipeline_test

# Redis. Dev container runs with persistence disabled (see docker-compose.dev.yml).
REDIS_URL=redis://localhost:6379/0

# Fernet key. Generate with:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
APP_MASTER_KEY=base64-encoded-32-byte-key-here

# Key provider selector. Only "env" is implemented in v1. "kms" comes later.
KEY_PROVIDER=env

# Stubbed auth. Real login replaces these later.
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@localhost

# TTLs in minutes (human readable here, converted to seconds in code).
# 10080 minutes = 7 days.
SESSION_TTL_MINUTES=10080
SSH_KEY_CACHE_TTL_MINUTES=30
SSH_POOL_IDLE_TIMEOUT_MINUTES=5
